<ResourceDictionary
    x:Class="Syncfusion.Maui.Core.Platform.Windows.Styles.RotatorStyles"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Syncfusion.Maui.Core.Rotator">

    <local:BoolToVisibilityConverter x:Key="booltovisibility" />
    <local:NavigationDirectionToOrientationConverter x:Key="navigationdirectiontoorientation" />
    <local:BrushToColorConverter x:Key="brushtocolor" />

    <Style TargetType="local:TabStripButton">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:TabStripButton">
                    <Border x:Name="grid">
                        <Ellipse
                            x:Name="PART_Ellipse"
                            Width="10"
                            Height="10">
                            <Ellipse.Stroke>
                                <SolidColorBrush Color="{Binding Path=UnselectedDotsBroderBrush, RelativeSource={RelativeSource Mode=TemplatedParent}, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource brushtocolor}}" />
                            </Ellipse.Stroke>
                            <Ellipse.Fill>
                                <SolidColorBrush Color="{Binding Path=UnselectedDotsBackground, RelativeSource={RelativeSource Mode=TemplatedParent}, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource brushtocolor}}" />
                            </Ellipse.Fill>
                        </Ellipse>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="PART_Ellipse"
                                            Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)"
                                            To="{Binding Path=SelectedDotsBackground, RelativeSource={RelativeSource Mode=TemplatedParent}, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource brushtocolor}}"
                                            Duration="0:0:0.2" />
                                        <ColorAnimation
                                            Storyboard.TargetName="PART_Ellipse"
                                            Storyboard.TargetProperty="(Ellipse.Stroke).(SolidColorBrush.Color)"
                                            To="{Binding Path=SelectedDotsBorderBrush, RelativeSource={RelativeSource Mode=TemplatedParent}, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource brushtocolor}}"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="PointerEnter">
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="PART_Ellipse"
                                            Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)"
                                            To="{Binding Path=SelectedDotsBackground, RelativeSource={RelativeSource Mode=TemplatedParent}, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource brushtocolor}}"
                                            Duration="0:0:0.2" />
                                        <ColorAnimation
                                            Storyboard.TargetName="PART_Ellipse"
                                            Storyboard.TargetProperty="(Ellipse.Stroke).(SolidColorBrush.Color)"
                                            To="{Binding Path=SelectedDotsBorderBrush, RelativeSource={RelativeSource Mode=TemplatedParent}, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource brushtocolor}}"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="PointerExit">
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="PART_Ellipse"
                                            Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)"
                                            To="{Binding Path=UnselectedDotsBackground, RelativeSource={RelativeSource Mode=TemplatedParent}, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource brushtocolor}}"
                                            Duration="0:0:0.2" />
                                        <ColorAnimation
                                            Storyboard.TargetName="PART_Ellipse"
                                            Storyboard.TargetProperty="(Ellipse.Stroke).(SolidColorBrush.Color)"
                                            To="{Binding Path=UnselectedDotsBroderBrush, RelativeSource={RelativeSource Mode=TemplatedParent}, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource brushtocolor}}"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Normal">
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="PART_Ellipse"
                                            Storyboard.TargetProperty="(Ellipse.Fill).(SolidColorBrush.Color)"
                                            To="{Binding Path=UnselectedDotsBackground, RelativeSource={RelativeSource Mode=TemplatedParent}, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource brushtocolor}}"
                                            Duration="0:0:0.2" />
                                        <ColorAnimation
                                            Storyboard.TargetName="PART_Ellipse"
                                            Storyboard.TargetProperty="(Ellipse.Stroke).(SolidColorBrush.Color)"
                                            To="{Binding Path=UnselectedDotsBroderBrush, RelativeSource={RelativeSource Mode=TemplatedParent}, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource brushtocolor}}"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="local:ThumbnailButton">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:ThumbnailButton">
                    <Border
                        x:Name="grid"
                        Width="88"
                        Height="88"
                        CornerRadius="8"
                        Background="Transparent">
                        <ContentPresenter
                            x:Name="Image_template"
                            Margin="1"
                            BorderThickness="2"
                            CornerRadius="8"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ThumbnailImageTemplate}"
                            ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}">
                            <ContentPresenter.BorderBrush>
                                <SolidColorBrush Color="{Binding Path=UnselectedThumbnailStroke, RelativeSource={RelativeSource Mode=TemplatedParent}, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource brushtocolor}}" />
                            </ContentPresenter.BorderBrush>
                        </ContentPresenter>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">

                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="Image_template"
                                            Storyboard.TargetProperty="(ContentPresenter.BorderBrush).(SolidColorBrush.Color)"
                                            To="{Binding Path=SelectedThumbnailStroke, RelativeSource={RelativeSource Mode=TemplatedParent}, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource brushtocolor}}"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </VisualState>

                                <VisualState x:Name="PointerEnter">
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="Image_template"
                                            Storyboard.TargetProperty="(ContentPresenter.BorderBrush).(SolidColorBrush.Color)"
                                            To="{Binding Path=SelectedThumbnailStroke, RelativeSource={RelativeSource Mode=TemplatedParent}, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource brushtocolor}}"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </VisualState>

                                <VisualState x:Name="PointerExit">
                                    <Storyboard>
                                        <ColorAnimation
                                            Storyboard.TargetName="Image_template"
                                            Storyboard.TargetProperty="(ContentPresenter.BorderBrush).(SolidColorBrush.Color)"
                                            To="{Binding Path=UnselectedThumbnailStroke, RelativeSource={RelativeSource Mode=TemplatedParent}, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource brushtocolor}}"
                                            Duration="0:0:0.2" />
                                    </Storyboard>
                                </VisualState>

                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="local:PlatformRotatorItem">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:PlatformRotatorItem">
                    <Border>
                        <ContentPresenter HorizontalContentAlignment="Stretch" Content="{TemplateBinding Content}" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="local:PlatformRotator">
        <Setter Property="Background" Value="#ececec" />
        <Setter Property="SelectedDotsBackground" Value="Black" />
        <Setter Property="UnselectedDotsBackground" Value="White" />
        <Setter Property="SelectedDotsBorderBrush" Value="Black" />
        <Setter Property="UnselectedDotsBroderBrush" Value="Black" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="local:PlatformRotator">
                    <Grid
                        x:Name="main_Grid"
                        Margin="{TemplateBinding Margin}"
                        Background="{TemplateBinding Background}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="auto" />
                        </Grid.RowDefinitions>
                        <Border
                            x:Name="prev_Border"
                            Width="35"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Stretch"
                            Background="#D2D2D4"
                            Canvas.ZIndex="1"
                            Opacity="0.7"
                            Visibility="{Binding Path=NavigationButtonVisibility, RelativeSource={RelativeSource TemplatedParent}}">
                            <Button
                                x:Name="PART_prevImage"
                                Width="30"
                                Margin="10,0,0,0"
                                Canvas.ZIndex="1"
                                Visibility="Visible">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Grid Background="Transparent">
                                            <Path
                                                x:Name="PART_Presenter"
                                                Width="15"
                                                Height="30"
                                                Margin="15,0,0,0"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Data="M-68.5,52 L-54,69.5 -68.787684,85.24501"
                                                Fill="{x:Null}"
                                                Stretch="Fill"
                                                Stroke="black"
                                                StrokeThickness="3">
                                                <Path.RenderTransform>
                                                    <TransformGroup>
                                                        <ScaleTransform ScaleX="-1" ScaleY="1" />
                                                        <SkewTransform AngleX="0" AngleY="0" />
                                                        <RotateTransform Angle="0" />
                                                        <TranslateTransform />
                                                    </TransformGroup>
                                                </Path.RenderTransform>
                                            </Path>
                                        </Grid>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Border>
                        <Border
                            x:Name="prev_Bordervertical"
                            Height="38"
                            VerticalAlignment="Top"
                            Background="#D2D2D4"
                            Canvas.ZIndex="1"
                            Opacity="0.5"
                            Visibility="{Binding Path=NavigationButtonVisibility, RelativeSource={RelativeSource TemplatedParent}}">
                            <Button
                                x:Name="PART_prevImagevertical"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Canvas.ZIndex="1">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Grid Background="Transparent">
                                            <Path
                                                Width="25"
                                                Height="40"
                                                Margin="0,0,0,0"
                                                Data="M16.261993,0L16.359985,0.065002445 16.454987,0 16.48999,0.15399169 32,11.294986 32,19.745 16.359985,8.5149861 0,19.745 0,11.294986 16.22699,0.15399169z"
                                                Fill="black"
                                                RenderTransformOrigin="0.5,0.5"
                                                Stretch="Uniform" />
                                        </Grid>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Border>

                        <!--<ScrollViewer x:Name="PART_ScrollContent" Grid.Row="0">-->
                        <Grid x:Name="SliderRoot" Grid.Row="0">

                            <local:SliderItemsPanel Orientation="{Binding Path=NavigationDirection, RelativeSource={RelativeSource Mode=TemplatedParent}, Converter={StaticResource navigationdirectiontoorientation}}">
                                <ContentPresenter x:Name="PART_Content" />
                                <ContentPresenter x:Name="PART_TempContent" />
                            </local:SliderItemsPanel>

                            <Border
                                Height="50"
                                VerticalAlignment="Bottom"
                                Background="LightGray"
                                Opacity="0.5"
                                Visibility="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ShowText, Converter={StaticResource booltovisibility}, Mode=TwoWay}">
                                <TextBlock
                                    x:Name="imgTextblock"
                                    Height="30"
                                    Margin="30,5,0,0"
                                    VerticalAlignment="Center"
                                    Canvas.ZIndex="1"
                                    FontSize="14"
                                    Foreground="Black"
                                    Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ImageText}" />
                            </Border>
                        </Grid>
                        <!--</ScrollViewer>-->

                        <Border
                            x:Name="next_Border"
                            Width="35"
                            HorizontalAlignment="Right"
                            Background="#D2D2D4"
                            Canvas.ZIndex="1"
                            Opacity="0.5"
                            Visibility="{Binding Path=NavigationButtonVisibility, RelativeSource={RelativeSource TemplatedParent}}">
                            <Button
                                x:Name="PART_nextImage"
                                Width="30"
                                Margin="0,0,2,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Grid Background="Transparent">
                                            <Path
                                                x:Name="PART_Presenter"
                                                Width="15"
                                                Height="30"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Data="M-68.5,52 L-54,69.5 -68.787684,85.24501"
                                                Fill="{x:Null}"
                                                Stretch="Fill"
                                                Stroke="black"
                                                StrokeThickness="3" />
                                        </Grid>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Border>
                        <Border
                            x:Name="next_Bordervertical"
                            Height="35"
                            VerticalAlignment="Bottom"
                            Background="#D2D2D4"
                            Canvas.ZIndex="1"
                            Opacity="0.7"
                            Visibility="{Binding Path=NavigationButtonVisibility, RelativeSource={RelativeSource TemplatedParent}}">
                            <Button
                                x:Name="PART_nextImagevertical"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Bottom">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Grid Background="Transparent">
                                            <Path
                                                Width="25"
                                                Height="40"
                                                Margin="0,0,0,0"
                                                Data="M0.085998535,0L16.112,11.464981 32,0.118011 32,8.3990061 16.115005,19.745 0,8.2079966 0,0.072997569z"
                                                Fill="black"
                                                RenderTransformOrigin="0.5,0.5"
                                                Stretch="Uniform" />
                                        </Grid>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Border>
                        <Grid
                            x:Name="TabStrip"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="Visible">
                            <local:TabStripControl x:Name="PART_TabStripButton">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <local:TabStripPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </local:TabStripControl>
                        </Grid>

                        <Grid
                            x:Name="Thumbnail"
                            Grid.Row="1"
                            Visibility="Collapsed">

                            <Button
                                x:Name="Thumb_PreviousImage"
                                Width="40"
                                Height="40"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Canvas.ZIndex="1"
                                CornerRadius="20"
                                Visibility="Collapsed">
                            </Button>

                            <Button
                                x:Name="Thumb_PreviousImagevertical"
                                Grid.Row="0"
                                Width="40"
                                Height="40"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Canvas.ZIndex="1"
                                CornerRadius="20"
                                Visibility="Collapsed">
                            </Button>

                            <ScrollViewer
                                x:Name="NavigationpButton"
                                HorizontalScrollBarVisibility="Hidden"
                                HorizontalScrollMode="Enabled"
                                IsHorizontalScrollChainingEnabled="True"
                                VerticalScrollBarVisibility="Hidden"
                                VerticalScrollMode="Enabled">

                                <local:ThumbnailControl x:Name="thumbHorizontalImage">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <local:ThumbnailPanel
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Top"
                                                Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </local:ThumbnailControl>

                            </ScrollViewer>
                            <Button
                                x:Name="Thumb_NextImage"
                                Width="40"
                                Height="40"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                CornerRadius="20"
                                Visibility="Collapsed">
                            </Button>
                            <Button
                                x:Name="Thumb_NextImagevertical"
                                Grid.Row="2"
                                Width="40"
                                Height="40"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Bottom"
                                CornerRadius="20"
                                Visibility="Collapsed">
                            </Button>
                        </Grid>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>


