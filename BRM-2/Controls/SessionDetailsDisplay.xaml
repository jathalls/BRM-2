<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="BRM_2.Controls.SessionDetailsDisplay"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:BRM_2.Controls"
    xmlns:sf="http://schemas.syncfusion.com/maui"
    xmlns:sfc="clr-namespace:Syncfusion.Maui.Picker;assembly=Syncfusion.Maui.Picker"
    xmlns:sfp="clr-namespace:Syncfusion.Maui.Popup;assembly=Syncfusion.Maui.Popup"
    xmlns:vm="clr-namespace:BRM_2.ViewModels"
    x:DataType="vm:SessionDetailsDisplayVM">
    <VerticalStackLayout>
        <Grid RowDefinitions="50,*,50">


            <Grid
                x:Name="formGrid"
                Grid.Row="1"
                ColumnDefinitions=".3*,.7*"
                HorizontalOptions="Center"
                RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                VerticalOptions="Center">

                <Label
                    Grid.Row="1"
                    Grid.Column="0"
                    HorizontalOptions="End"
                    Text="Session Tag:-"
                    VerticalOptions="Center" />
                <Label
                    x:Name="SessionTagEntry"
                    Grid.Row="1"
                    Grid.Column="1"
                    HorizontalOptions="Start"
                    Text="{Binding SessionTag}"
                    VerticalOptions="Center" />

                <Label
                    Grid.Row="2"
                    Grid.Column="0"
                    HorizontalOptions="End"
                    Text="Start:-"
                    VerticalOptions="Center" />
                <HorizontalStackLayout
                    Grid.Row="2"
                    Grid.Column="1"
                    HorizontalOptions="Start"
                    VerticalOptions="Center">

                    <Label
                        x:Name="startDateButton"
                        Margin="5,0,0,0"
                        Background="White"
                        Text="{Binding StartDate, StringFormat='{0:dd_MM_yyyy HH:mm}'}"
                        TextColor="#000000" />

                </HorizontalStackLayout>

                <Label
                    Grid.Row="3"
                    Grid.Column="0"
                    HorizontalOptions="End"
                    Text="End:-"
                    VerticalOptions="Center" />

                <HorizontalStackLayout
                    Grid.Row="3"
                    Grid.Column="1"
                    HorizontalOptions="Start"
                    VerticalOptions="Center">

                    <Label
                        x:Name="endDateButton"
                        Margin="5,0,0,0"
                        Background="White"
                        Text="{Binding EndDate, StringFormat='{0:dd_MM_yyyy HH:mm}'}"
                        TextColor="#000000" />
                </HorizontalStackLayout>



                <Label
                    Grid.Row="4"
                    Grid.Column="0"
                    HorizontalOptions="End"
                    Text="File Location:-"
                    VerticalOptions="Center" />

                <Label
                    Grid.Row="4"
                    Grid.Column="1"
                    HorizontalOptions="Fill"
                    Text="{Binding FileLocation}"
                    TextColor="{Binding FileLocationColor}"
                    VerticalOptions="Center" />


                <Label
                    Grid.Row="5"
                    Grid.Column="0"
                    HorizontalOptions="End"
                    Text="Location:-"
                    VerticalOptions="Center" />
                <Label
                    x:Name="sfLocationCombo"
                    Grid.Row="5"
                    Grid.Column="1"
                    HorizontalOptions="Start"
                    Text="{Binding Location}" />

                <Label
                    Grid.Row="6"
                    Grid.Column="0"
                    HorizontalOptions="End"
                    Text="GPS Co-ordinates:-"
                    VerticalOptions="Center" />
                <HorizontalStackLayout
                    Grid.Row="6"
                    Grid.Column="1"
                    HorizontalOptions="Start"
                    VerticalOptions="Center">
                    <Label Text="Lat:-" VerticalOptions="Center" />
                    <Label
                        Text="{Binding Latitude}"
                        VerticalOptions="Center"
                        WidthRequest="150" />
                    <Label Text="Longit:-" VerticalOptions="Center" />
                    <Label
                        Text="{Binding Longitude}"
                        VerticalOptions="Center"
                        WidthRequest="150" />
                    <VerticalStackLayout>
                        <Button
                            x:Name="MapButton"
                            Command="{Binding MapButtonCommand}"
                            HeightRequest="25"
                            Text="MAP" />

                    </VerticalStackLayout>

                </HorizontalStackLayout>

                <Label
                    Grid.Row="7"
                    Grid.Column="0"
                    HorizontalOptions="End"
                    Text="Operator:-"
                    VerticalOptions="Center" />
                <Label
                    x:Name="sfOperatorCombo"
                    Grid.Row="7"
                    Grid.Column="1"
                    HorizontalOptions="Start"
                    Text="{Binding Operator}" />

                <Label
                    Grid.Row="8"
                    Grid.Column="0"
                    HorizontalOptions="End"
                    Text="Equipment:-"
                    VerticalOptions="Center" />
                <Label
                    x:Name="sfEquipmentCombo"
                    Grid.Row="8"
                    Grid.Column="1"
                    HorizontalOptions="Start"
                    Text="{Binding Equipment}" />

                <Label
                    Grid.Row="9"
                    Grid.Column="0"
                    HorizontalOptions="End"
                    Text="Microphone:-"
                    VerticalOptions="Center" />
                <Label
                    x:Name="sfMicrophoneCombo"
                    Grid.Row="9"
                    Grid.Column="1"
                    HorizontalOptions="Start"
                    Text="{Binding Microphone}" />

                <Label
                    Grid.Row="10"
                    Grid.Column="0"
                    HorizontalOptions="End"
                    Text="Weather:-"
                    VerticalOptions="Center" />
                <HorizontalStackLayout Grid.Row="10" Grid.Column="1">
                    <Label
                        x:Name="weatherEntry"
                        Text="{Binding WeatherText}"
                        WidthRequest="800" />

                </HorizontalStackLayout>


                <sf:SfTextInputLayout
                    Grid.Row="11"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    ContainerType="Outlined"
                    Hint="Notes:- ">
                    <Editor
                        x:Name="notesEditor"
                        AutoSize="TextChanges"
                        Text="{Binding SessionNotes}" />
                </sf:SfTextInputLayout>






            </Grid>
        </Grid>
    </VerticalStackLayout>
</ContentView>
