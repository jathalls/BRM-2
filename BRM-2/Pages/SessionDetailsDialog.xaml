<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:BRM_2.Controls"
             x:Class="BRM_2.Pages.SessionDetailsDialog"
             Title="SessionDetails">
    <VerticalStackLayout>
        <local:SessionDetailsForm x:Name="sessionDetailsForm" HorizontalOptions="Fill">

        </local:SessionDetailsForm>
        <HorizontalStackLayout >
            <Button x:Name="OKButton" Clicked="OKButton_Clicked" Text="OK"/>
            <Button x:Name="CancelButton" Clicked="CancelButton_Clicked" Text="CANCEL"/>
        </HorizontalStackLayout>

    </VerticalStackLayout>
</ContentPage>
